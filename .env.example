# Database Configuration
# Use DATABASE_URL (Neon/Supabase) ou variáveis individuais

# Opção 1: DATABASE_URL (recomendado para Vercel)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Opção 2: Variáveis individuais (local development)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=taf_db
# DB_USER=postgres
# DB_PASSWORD=sua_senha

# Tomorrow.io API
TOMORROW_IO_API_URL=https://api.tomorrow.io/v4/weather/forecast
TOMORROW_IO_API_KEY=sua_chave_api_tomorrow

# REDEMET API
REDEMET_API_URL=https://api-redemet.decea.mil.br/mensagens/taf
REDEMET_API_KEY=sua_chave_api_redemet

# Application
ENV=production
DEBUG=false
